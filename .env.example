# Configuração Crystalize

# Segurança
# Obrigatório em produção. Gere com:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Banco de Dados
# Desenvolvimento: SQLite (padrão)
DATABASE_URL=sqlite:///./crystalize.db
# Produção (Railway/Fly.io/Neon): PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/crystalize

# Limites
MAX_CODE_SIZE=10000
EXECUTION_TIMEOUT=10

# Docker
DOCKER_IMAGE=crystal:latest

# Desenvolvimento
DEBUG=True
# development | production (em production, ALLOWED_ORIGINS='*' causa RuntimeError)
ENVIRONMENT=development

# CORS — em produção, OBRIGATÓRIO definir domínios específicos (wildcard '*' é bloqueado)
# Exemplo: ALLOWED_ORIGINS=https://app.crystalize.dev,https://crystalize.dev
# Desenvolvimento: pode usar * ou http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# LLM Router
LLM_PRIMARY_BACKEND=ollama
LLM_FALLBACK_BACKENDS=openai_compatible
LLM_PRIMARY_MODEL=qwen2.5-coder:7b

# Ollama backend (local)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible backend (OpenAI, DeepSeek, Together AI, LM Studio, etc.)
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
